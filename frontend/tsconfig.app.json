{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022", "useDefineForClassFields": true, "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false, "skipLibCheck": true, "esModuleInterop": true,
    "module": "ESNext", "moduleResolution": "bundler", "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": true, "noEmit": true, "jsx": "react-jsx", "strict": true, "types": ["vite/client"]
  },
  "include": ["src"]
}
